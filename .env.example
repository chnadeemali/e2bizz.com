NODE_ENV=development
APP_ENV=development
APP_NAME=E2BIZZ
APP_URL=https://e2bizz.com

DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/e2bizz
DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/e2bizz

AUTH_SECRET=replace_with_long_random_secret
AUTH_TRUST_HOST=true

REDIS_URL=redis://HOST:6379

STORAGE_PROVIDER=s3
S3_ENDPOINT=https://your-object-storage-endpoint
S3_REGION=auto
S3_BUCKET=e2bizz-media
S3_ACCESS_KEY_ID=xxxxx
S3_SECRET_ACCESS_KEY=xxxxx
S3_PUBLIC_BASE_URL=https://cdn.e2bizz.com

MAIL_PROVIDER=resend
MAIL_FROM=noreply@e2bizz.com
MAIL_REPLY_TO=support@e2bizz.com
RESEND_API_KEY=xxxxx

CONTACT_RELAY_EMAIL=support@e2bizz.com

IMAGE_MAX_FILE_SIZE_MB=8
IMAGE_MAX_FILES_PER_AD=12

RATE_LIMIT_POST_AD_PER_DAY=5
RATE_LIMIT_CONTACT_PER_HOUR=20
RATE_LIMIT_AUTH_ATTEMPTS_PER_15_MIN=10

MODERATION_AUTO_PUBLISH=false
ENABLE_PHONE_LOGIN=false
ENABLE_WHATSAPP_CONTACT=true
ENABLE_EMAIL_RELAY=true
ENABLE_PUBLIC_PHONE_REVEAL=true
